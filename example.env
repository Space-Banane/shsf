# API server port
PORT=5000

# Database connection string (MariaDB/MySQL)
DATABASE_URL=mysql://user:password@db:3306/shsf

# Domain name for your deployment (optional)
DOMAIN=shsf.example.com

# Public UI URL
UI_URL=http://localhost:3000

# Disable registration after your account is created
REGISTER_DISABLED=false

# API URL for the UI to connect to
REACT_APP_API_URL=http://localhost:5000

# UI port (should match docker-compose)
REACT_APP_PORT=3000

# Comma-separated list of allowed CORS origins
CORS_URLS=http://localhost:3000,https://shsf.example.com

# Rate limit in milliseconds
RATELIMIT=5000

# Instance secret — used to encrypt sensitive data such as git passwords at rest.
# Must be a random 32-character (256-bit) hex string. Generate with: openssl rand -hex 32
INSTANCE_SECRET=changeme_replace_with_a_random_32_byte_hex_string
